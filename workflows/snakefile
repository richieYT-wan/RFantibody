# RFantibody/workflows/snakefile
import sys
from pathlib import Path
from utils import find_repo_root

WORKFLOW_DIR = Path(__file__).resolve().parent
sys.path.insert(0, str(WORKFLOW_DIR))

# add ADA env
ROOT=find_repo_root()
ADAENV = (ROOT / "workflows" / "envs" / "ada.yaml").resolve()

# Define working directory (relative to the Snakefile)
workdir: find_repo_root()
# workdir: "../../" # This sets the working directory to the RFantibody/ root

# Load configuration from config.yaml
configfile: "config/config.yaml"

# Reading executor from config file and forcing to install a rule to run setup.sh (for uv) on gbatch
EXEC = config.get("executor", "local")
if EXEC=="googlebatch":
    include: "rules/gbatch_uvsetup.smk" # A new rule that forces a run of setup.sh on google batch

SETUP_TARGETS = ['data/00_setup/.uv_setup.complete'] if EXEC == 'googlebatch' else []
def setup_inputs():
    return ["data/00_setup/.uv_setup.complete"] if EXEC == "googlebatch" else []


# Include rule files
include: "rules/process_framework.smk"
include: "rules/process_target.smk" # New include
include: "rules/generate_patches.smk"
include: "rules/run_rfantibody.smk"
include: "rules/parse_outputs.smk"


# Run ID handling
RUN_IDS = list(config.get("runs", {}).keys())
rule all:
    input:
        SETUP_TARGETS
        + expand("data/02_intermediate/framework/{framework_id}_HLT.pdb",
                framework_id=config["frameworks"].keys()) # Get the HLT formatted frameworks, runs the make_framework.smk
        + expand("data/02_intermediate/target/{target_id}_processed.pdb",
                target_id=config["targets"].keys()) # Get the processed targets, runs the make_target.smk
        + expand("data/03_jobs/{run_id}/jobs_list.tsv", run_id=RUN_IDS) # Creates the run jobs, runs generate_patches.smk
        + expand("data/04_rfab/{run_id}/rfab_run.complete", run_id=RUN_IDS) # Runs the jobs, runs run_rfantibody.smk
        + expand("data/05_results/{run_id}/merged_parsed_outputs.csv", run_id=RUN_IDS) # parses the outputs, runs parse_outputs.smk
       
